# Local dev: copy to .env.local (gitignored):
# NEXT_PUBLIC_API_URL=http://localhost:8080/api/user
#
# Vercel (my-app project) — set ONE of these for Production + Preview, then Redeploy:
# NEXT_PUBLIC_API_URL=https://YOUR-USER-API.vercel.app/api/user
#   OR
# USER_API_URL=https://YOUR-USER-API.vercel.app/api/user
#
# The app calls your User API via a same-origin proxy (/api/user-proxy) on Vercel to avoid CORS issues.
